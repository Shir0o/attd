rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // User profiles: Only the user can read/write their own profile
    match /users/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    // Families: Shared data, accessible by any authenticated user
    match /families/{familyId} {
      allow read, write: if isAuthenticated();
    }

    // Sessions: Shared data, accessible by any authenticated user
    match /sessions/{sessionId} {
      allow read, write: if isAuthenticated();
      
      // Allow access to subcollections (versions)
      match /versions/{versionId} {
        allow read, write: if isAuthenticated();
      }
    }
  }
}